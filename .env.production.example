# ============================================
# FINTRACK - PRODUCTION ENVIRONMENT VARIABLES
# ============================================
# Copie este arquivo para .env.production e preencha com valores reais
# NUNCA commite o arquivo .env.production no Git!

# ============================================
# POSTGRES DATABASE
# ============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD_HERE
POSTGRES_DB=fintrack
POSTGRES_PORT=5432

# ============================================
# REDIS
# ============================================
REDIS_PORT=6379

# ============================================
# BACKEND API
# ============================================
BACKEND_PORT=4000

# JWT Secret (MÍNIMO 32 caracteres!)
# Gerar: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32

# URL do Frontend (para CORS)
FRONTEND_URL=https://seudominio.com

# ============================================
# FRONTEND
# ============================================
FRONTEND_PORT=3000

# URL da API Backend
VITE_API_URL=https://api.seudominio.com/api/v1
