# ============================================
# FINTRACK - FREE HOSTING CONFIGURATION
# ============================================
# Use este arquivo para deploy gratuito (Render, Vercel, Neon, Upstash)
# Copie para .env e preencha os valores reais

# ============================================
# APPLICATION
# ============================================
NODE_ENV=production
PORT=4000

# Free hosting mode (desabilita workers)
FREE_HOSTING=true
ENABLE_WORKERS=false

# ============================================
# DATABASE - NEON (https://neon.tech)
# ============================================
# Copie a connection string do painel Neon
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DATABASE?sslmode=require

# Exemplo:
# DATABASE_URL=postgresql://fintrack_owner:AbC123XyZ@ep-cool-sea-123456.us-east-2.aws.neon.tech/fintrack?sslmode=require

# ============================================
# JWT SECRET
# ============================================
# Gerar: openssl rand -base64 32
# MÍNIMO 32 caracteres!
JWT_SECRET=your-super-secure-jwt-secret-key-minimum-32-characters

# ============================================
# FRONTEND URL - VERCEL
# ============================================
# URL do frontend Vercel (para CORS)
FRONTEND_URL=https://fintrack.vercel.app
# ou: https://your-project-name.vercel.app

# ============================================
# REDIS - UPSTASH (https://upstash.com)
# ============================================
# Copie do painel Upstash → Details
REDIS_HOST=your-endpoint.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your_upstash_token_here

# Ou Redis URL completa (alternativa)
# REDIS_URL=redis://:PASSWORD@HOST:PORT

# ============================================
# OPCIONAL: MONITORING
# ============================================
# Sentry (https://sentry.io) - 5K eventos/mês grátis
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ============================================
# NOTAS IMPORTANTES
# ============================================
#
# 1. Render Free Tier:
#    - Sleep após 15 min inatividade (cold start ~30s)
#    - Use cron-job.org para pingar /api/v1/health a cada 10 min
#
# 2. Neon Free Tier:
#    - 3 GB storage (suficiente para portfólio)
#    - 1 projeto
#
# 3. Upstash Free Tier:
#    - 10,000 comandos por dia (~7 cmds/min)
#    - Suficiente para cache básico
#
# 4. Workers:
#    - Desabilitados por padrão no free tier
#    - Se precisar, use Railway Redis (trial $5)
#
# 5. Security:
#    - NUNCA commite este arquivo com valores reais!
#    - Adicione .env ao .gitignore
#    - Use secrets do Render/Vercel para produção
