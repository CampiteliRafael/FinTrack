generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String         @map("password_hash")
  name          String
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  accounts           Account[]
  categories         Category[]
  transactions       Transaction[]
  refreshTokens      RefreshToken[]
  goals              Goal[]
  installments       Installment[]
  passwordResetTokens PasswordResetToken[]
  notifications      Notification[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Account {
  id                String        @id @default(uuid())
  userId            String        @map("user_id")
  name              String
  initialBalance    Decimal       @default(0) @map("initial_balance") @db.Decimal(20, 2)
  currentBalance    Decimal       @default(0) @map("current_balance") @db.Decimal(20, 2)
  availableBalance  Decimal       @default(0) @map("available_balance") @db.Decimal(20, 2)
  reservedAmount    Decimal       @default(0) @map("reserved_amount") @db.Decimal(20, 2)
  monthlyIncome     Decimal?      @map("monthly_income") @db.Decimal(20, 2)
  monthlyIncomeDay  Int?          @map("monthly_income_day")
  lastTransactionAt DateTime?     @map("last_transaction_at")
  type              AccountType
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  deletedAt         DateTime?     @map("deleted_at")

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions   Transaction[]
  installments   Installment[]
  accountEvents  AccountEvent[]

  @@index([userId])
  @@index([deletedAt])
  @@map("accounts")
}

enum AccountType {
  checking
  savings
  cash
}

model AccountEvent {
  id             String           @id @default(uuid())
  accountId      String           @map("account_id")
  type           AccountEventType
  amount         Decimal          @db.Decimal(20, 2)
  transactionId  String?          @map("transaction_id")
  installmentId  String?          @map("installment_id")
  description    String?
  balanceBefore  Decimal          @map("balance_before") @db.Decimal(20, 2)
  balanceAfter   Decimal          @map("balance_after") @db.Decimal(20, 2)
  createdAt      DateTime         @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([transactionId])
  @@index([installmentId])
  @@index([createdAt])
  @@map("account_events")
}

enum AccountEventType {
  transaction_income
  transaction_expense
  installment_payment
  transfer_in
  transfer_out
  adjustment
  initial_balance
}

model Category {
  id           String          @id @default(uuid())
  userId       String          @map("user_id")
  name         String
  color        String          @default("#6B7280")
  icon         String          @default("Tag")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  deletedAt    DateTime?       @map("deleted_at")

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  goals        Goal[]
  installments Installment[]

  @@index([userId])
  @@index([deletedAt])
  @@map("categories")
}

model Transaction {
  id            String          @id @default(uuid())
  userId        String          @map("user_id")
  accountId     String          @map("account_id")
  categoryId    String          @map("category_id")
  type          TransactionType
  amount        Decimal         @db.Decimal(20, 2)
  description   String?
  date          DateTime
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  deletedAt     DateTime?       @map("deleted_at")

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  account       Account         @relation(fields: [accountId], references: [id], onDelete: Restrict)
  category      Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  installments  Installment[]

  @@index([userId])
  @@index([accountId])
  @@index([categoryId])
  @@index([date])
  @@index([deletedAt])
  @@map("transactions")
}

enum TransactionType {
  income
  expense
}

model Goal {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  name        String
  targetAmount Decimal  @map("target_amount") @db.Decimal(20, 2)
  currentAmount Decimal @default(0) @map("current_amount") @db.Decimal(20, 2)
  deadline    DateTime?
  categoryId  String?   @map("category_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([deletedAt])
  @@map("goals")
}

model Installment {
  id            String          @id @default(uuid())
  userId        String          @map("user_id")
  transactionId String?         @map("transaction_id")
  description   String
  totalAmount   Decimal         @map("total_amount") @db.Decimal(20, 2)
  installments  Int
  currentInstallment Int        @default(0) @map("current_installment")
  accountId     String          @map("account_id")
  categoryId    String          @map("category_id")
  startDate     DateTime        @map("start_date")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  deletedAt     DateTime?       @map("deleted_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  account     Account     @relation(fields: [accountId], references: [id], onDelete: Restrict)
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([deletedAt])
  @@map("installments")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}

enum NotificationType {
  GOAL_ACHIEVED
  REPORT_READY
  WELCOME
  SYSTEM
}
